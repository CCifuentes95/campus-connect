# CampusConnect — environment template. Copy to `.env.local` for local dev.
# `.env*` is gitignored. In CI these come from GitHub Secrets (see .github/workflows/deploy.yml).

# --- Firebase web config (client SDK) ---------------------------------------
# NOT secret, but embedded into the client bundle at `next build` time, so they must be
# present wherever the build runs (locally AND the GitHub Action).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Local emulator wiring ---------------------------------------------------
# Set to "true" to point the app at the Firebase Emulator Suite (see firebase.json).
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIRESTORE_EMULATOR_HOST=localhost:8080

# --- Notes -------------------------------------------------------------------
# The Firebase Admin SDK is NOT used by the Next app (ADR-0004): all privileged
# operations live in Cloud Functions. So no service-account key belongs here.
# CI-only secrets (not in this file): VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID,
# FIREBASE_SERVICE_ACCOUNT.
